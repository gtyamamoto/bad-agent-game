## ROGUE NEURAL - Context API Structure

```mermaid
classDiagram
    class GameContext {
        +gameState: GameState
        +scenario: Scenario | null
        +phases: Phase[]
        +currentPhaseIndex: number
        +chaosLevel: number
        +logs: Log[]
        +isLoading: boolean
        +startGame: () => void
        +handleChoice: (choiceId: string) => void
        +resetGame: () => void
    }

    class GameStateProvider {
        +GameStateContext: Context~GameState~
        +scenarioContext: Context~Scenario~
        +uiStateContext: Context~UIState~
        +children: ReactNode
        +provideGameState()
    }

    class useGameLogic {
        +gameState: GameState
        +scenario: Scenario
        +phases: Phase[]
        +currentPhaseIndex: number
        +chaosLevel: number
        +logs: Log[]
        +isLoading: boolean
        +startGame: () => void
        +handleChoice: () => void
        +resetGame: () => void
    }

    class GameState {
        +status: 'loading' | 'scenario' | 'playing' | 'ended'
        +timestamp: Date
        +version: number
    }

    class Scenario {
        +id: string
        +title: string
        +description: string
        +context: string
        +entities: Entity[]
        +phases: Phase[]
    }

    class Phase {
        +id: string
        +title: string
        +prompt: string
        +choices: Choice[]
        +aiContext: AIContext
    }

    GameContext --> GameStateProvider : created by
    useGameLogic --> GameContext : consumes
    GameStateProvider --> GameStateContext : provides
    GameStateProvider --> scenarioContext : provides
    GameStateProvider --> uiStateContext : provides
```

